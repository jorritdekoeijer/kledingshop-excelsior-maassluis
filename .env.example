# === Verplicht (Supabase) ===
# Project-URL (https://<ref>.supabase.co) — nooit de anon- of service-role key hier zetten.
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Zelfde basis-URL als SUPABASE_URL; gebruikt o.a. door de publieke beeld-proxy.
# Als deze ontbreekt of fout is (bijv. per ongeluk een JWT), wordt SUPABASE_URL gebruikt.
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co

# === Productie (Vercel / hosting) ===
# Publieke basis-URL zonder trailing slash — nodig voor Mollie redirect-URL’s, sitemap en metadata.
# Op Vercel kun je deze handmatig zetten op je definitieve domein.
NEXT_PUBLIC_SITE_URL=https://www.jouw-domein.nl

# Beveiligt POST /api/cron/monthly-email (header x-cron-secret). Genereer een lange willekeurige string.
CRON_SECRET=

# === Optioneel ===
# Fallback ontvanger voor de maandelijkse samenvatting als die niet in het dashboard staat
# MONTHLY_DIGEST_EMAIL=commissie@club.nl

# YouTube video-id voor optionele embed op de homepage (alleen publiek)
# NEXT_PUBLIC_YOUTUBE_VIDEO_ID=

# === Mollie & SMTP ===
# Worden in productie meestal in Beheer → Instellingen gezet (database), niet in .env.
# Zet hier alleen iets als je lokaal test zonder dashboard.

# === Automatisch op Vercel ===
# VERCEL_URL=...
